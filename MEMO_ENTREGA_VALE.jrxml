	<property name="ireport.jasperserver.user" value="caballerof"/>
	<property name="ireport.jasperserver.reportUnit" value="/Reportes/MEMO_ENTREGA_VALE"/>
	<property name="ireport.jasperserver.report.resource" value="/Reportes/MEMO_ENTREGA_VALE_files/main_jrxml"/>
	<parameter name="P_ID_DET_PEDIDO" class="java.lang.Integer"/>
	<parameter name="P_USUARIO" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT c.id_pedido_vale
      ,c.fecha_pedido
      ,cc.precio_unitario
      ,d.cantidad_vales
      ,d.fecha_desde
      ,d.fecha_hasta
      ,d.dias_semana
      ,d.observacion
      ,p.id_persona||'-'||p.nombres||' '||p.apellidos colaborador
      , (
        SELECT listagg(di.descripcion,',') WITHIN GROUP( ORDER BY nro_dia)
        FROM dias_vale di
        WHERE EXISTS (
          SELECT 1
          FROM TABLE(apex_string.split_numbers(p_str => d.dias_semana , p_sep =>':' ))t
          WHERE t.column_value = di.nro_dia
        )
      ) AS dias_vale
      ,(cc.precio_unitario * d.cantidad_vales) as monto_vales
FROM  cab_pedido_vale c
     ,cab_compra_vale cc
     ,det_pedido_vale d
     ,persona p
WHERE d.id_det_pedido_vale =  $P{P_ID_DET_PEDIDO}  
AND cc.ped_id_pedido_vale = c.id_pedido_vale
AND d.ped_id_pedido_vale = c.id_pedido_vale
AND p.id_persona = d.per_id_persona]]>
	</queryString>
